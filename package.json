{
  "name": "manic-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Bun workspace for Manic framework development",
  "workspaces": [
    "core",
    "bundler",
    "providers",
    "create-manic",
    "tui",
    "plugins/*",
    "example-starter",
    "example-chatbot",
    "demo"
  ],
  "scripts": {
    "setup": "bash setup.sh && bash scripts/install-local-hooks.sh",
    "dev": "cd demo && bun dev",
    "build": "bun run -r build",
    "test": "bun run -r test",
    "test:integration": "bun test scripts/test/core-integration/**/*.test.ts",
    "test:watch": "bun test --watch",
    "lint": "bunx oxlint --config .oxlintrc.json core/src bundler/src providers/src",
    "format": "bunx oxfmt --config .oxfmt.json core/src bundler/src providers/src",
    "ci:lint": "bunx oxlint --config .oxlintrc.json .",
    "ci:format": "bunx oxfmt --check --config .oxfmt.json .",
    "hooks": "bash scripts/install-local-hooks.sh",
    "resolve-workspace-deps": "bun scripts/resolve-workspace-deps-for-push.ts"
  },
  "devDependencies": {}
}
