{
  "name": "manic-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Bun workspace for Manic framework development",
  "workspaces": [
    "core",
    "bundler",
    "providers",
    "create-manic",
    "tui",
    "plugins/*",
    "docs",
    "example-starter",
    "example-chatbot",
    "demo"
  ],
  "scripts": {
    "setup": "bash setup.sh",
    "dev": "cd demo && bun dev",
    "build": "bun run -r build",
    "test": "bun run -r test",
    "release": "bash scripts/release.sh"
  },
  "devDependencies": {}
}
