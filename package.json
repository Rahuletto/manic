{
  "name": "manic-monorepo",
  "devDependencies": {
    "@types/bun": "latest",
    "next": "16.2.3",
    "oxc-minify": "^0.125.0",
    "oxlint": "^1.60.0",
    "typescript": "^5"
  },
  "private": true,
  "scripts": {
    "dev": "cd demo && bun run dev",
    "build": "cd demo && bun run build",
    "typecheck": "cd packages/manic && bun run tsc --noEmit",
    "agents:plugin": "bun scripts/generate-plugin-agents.ts"
  },
  "workspaces": [
    "packages/*",
    "plugins/*",
    "demo",
    "docs",
    "examples/*"
  ]
}
