#!/bin/bash
# Resolve workspace: protocol in demo before commit (Vercel / remote installs).

set -e

ROOT=$(git rev-parse --show-toplevel)
cd "$ROOT"

STAGED=$(git diff --cached --name-only)
if ! echo "$STAGED" | grep -qE '^demo/package\.json$'; then
  exit 0
fi

echo "🔧 Resolving workspace: protocol for deploy (demo)..."
bun "$ROOT/scripts/resolve-workspace-deps-for-push.ts"
bun install

[ -f "$ROOT/demo/package.json" ] && git add demo/package.json
[ -f "$ROOT/bun.lock" ] && git add bun.lock

echo "✓ Deployable package.json ready (npm semver, not workspace:)"
