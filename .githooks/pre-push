#!/bin/bash
# Pre-push hook: Run tests before pushing

set -e

WORKSPACE_ROOT=$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)

echo ""
echo "🔐 Running pre-push validation..."
echo ""

cd "$WORKSPACE_ROOT"

# Run package tests
echo "📦 Running package tests..."
if ! bun run -r test 2>&1 | tail -20; then
  echo ""
  echo "⚠️  Package tests had issues"
fi

# Run workspace integration tests
echo ""
echo "🔌 Running workspace integration tests..."
if ! bun run test:integration 2>&1 | tail -20; then
  echo ""
  echo "❌ Integration tests failed. Fix issues before pushing."
  echo ""
  exit 1
fi

echo ""
echo "✅ All validations passed. Proceeding with push."
echo ""
exit 0
